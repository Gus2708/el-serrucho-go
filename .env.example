# Copy this to .env.local and fill in your values
# Never commit .env.local to git

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# URL de n8n — necesaria para el reenvío de las "solicitudes de ayuda" del bot.
# En la tienda apunta a la PC en la LAN; fuera de la tienda, a un túnel/URL pública.
EXPO_PUBLIC_N8N_URL=http://192.168.1.143:5678

# Only needed for Edge Function deployment (set in Supabase dashboard)
# GEMINI_API_KEY=your-gemini-api-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
